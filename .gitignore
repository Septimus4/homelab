# real secrets — never commit (pass 2 will switch to SOPS-encrypted *.sops.env)
**/.env
!**/.env.example

# credentials store
.secrets/
*.secret

# komodo runtime env with real values
komodo/compose.env

# NOTE: element-web/element-call config.json are COMMITTED (not ignored).
# They hold only public client config (the public homeserver/call URLs that
# element-web serves to every browser anyway) — no secrets. They MUST be in
# the repo so the Komodo GitOps clone has them; otherwise the bind-mount
# source is missing and Docker creates an empty *directory* there, which
# fails with "not a directory" on container start.

# editor / OS noise
.DS_Store
*.swp
*.bak
*.bak-*
