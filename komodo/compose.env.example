# Komodo deployment env — copy to compose.env and fill in. (compose.env is gitignored.)
COMPOSE_KOMODO_IMAGE_TAG=2
COMPOSE_KOMODO_BACKUPS_PATH=/home/youruser/homelab-komodo/backups
# Absolute path to this git repo on the host (bind-mounted into Periphery as /repo).
HOMELAB_REPO_PATH=/home/youruser/homelab

# Site config (compose interpolation: Traefik Host rule for the Komodo UI).
DOMAIN=example.com

# MongoDB credentials (Komodo's own datastore)
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=change_me

# Public URL (behind Traefik, LAN/VPN only)
KOMODO_HOST=https://komodo.example.com
KOMODO_WEBHOOK_SECRET=change_me

# First admin user (created on first start)
KOMODO_INIT_ADMIN_USERNAME=admin
KOMODO_INIT_ADMIN_PASSWORD=change_me

# The local server this bundled Periphery registers as
KOMODO_FIRST_SERVER_NAME=your-server

# Periphery
PERIPHERY_ROOT_DIRECTORY=/etc/komodo
PERIPHERY_CORE_ADDRESS=ws://core:9120
PERIPHERY_CONNECT_AS=${KOMODO_FIRST_SERVER_NAME}
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub

# Enable username/password login + init admin creation
KOMODO_LOCAL_AUTH=true
KOMODO_JWT_SECRET=change_me

# Trust the bundled local periphery (its pubkey is in the shared keys volume)
KOMODO_PERIPHERY_PUBLIC_KEYS=file:/config/keys/periphery.pub
