# games stack — copy to .env and fill in (gitignored).
# cp stacks/games/.env.example stacks/games/.env

# --- CS2 (kus/cs2-modded-server) ---
# GSLT (Game Server Login Token) from https://steamcommunity.com/dev/managegameservers (app 730).
CS2_GSLT=
# RCON password for remote admin.
CS2_RCON_PASSWORD=change_me
# Server join password ("" = public).
CS2_PASSWORD=
# Steam Web API key — ONLY needed if you use workshop maps ("" otherwise).
CS2_STEAM_API_KEY=

# --- Ships At Sea dedicated server (app 3951240, v0.8.7 public test) ---
# Beta branch NAME. `public_test` is accepted by steamcmd (the hidden branch isn't listed
# in app_info; `publictest` is rejected). The branch's depots require an account that OWNS
# Ships At Sea — set SAS_STEAM_USER/PASS below (anonymous gets "Missing configuration").
# Set SAS_BETA="" to pull the default (non-beta) build once v0.8.7 ships to stable.
SAS_BETA=public_test
# Branch password from the official v0.8.7 announcement.
SAS_BETA_PASSWORD=SaSPublicTest
# REQUIRED: a Steam account that OWNS Ships At Sea (anonymous can't install app 3951240).
# After the one-time interactive login (images/ships-at-sea/README.md) the Steam Guard token
# is cached in the games_sas_steam volume, so you can leave SAS_STEAM_PASS blank.
SAS_STEAM_USER=
SAS_STEAM_PASS=
# In-game server name and optional join password.
SAS_SERVER_NAME=Homelab Ships At Sea
SAS_PASSWORD=
# Override only if the launcher auto-detect fails (path relative to the install root),
# e.g. SAS_LAUNCH=SASServer.sh
SAS_LAUNCH=
# Extra launch args appended to the server command.
SAS_EXTRA_ARGS=
