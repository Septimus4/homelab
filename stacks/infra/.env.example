# infra stack — copy to .env and fill in (pass 2: encrypt with SOPS/age).

# Site config (compose interpolation: Traefik Host rules + AdGuard DNS bind address).
DOMAIN=example.com
SERVER_IP=192.168.1.2

# OVH DNS API credentials for Traefik's `ovh` ACME dns-challenge resolver.
# Traefik (lego) reads these OVH_* env vars natively — no Vault needed.
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=change_me
OVH_APPLICATION_SECRET=change_me
OVH_CONSUMER_KEY=change_me
