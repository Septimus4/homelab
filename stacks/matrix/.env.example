# matrix stack secrets/config — copy to .env and fill in (kept as-is for pass 1)
POSTGRES_PASSWORD=change_me
LIVEKIT_KEY=change_me
LIVEKIT_SECRET=change_me

# Site config (compose interpolation).
DOMAIN=example.com
# Host NIC LiveKit gathers ICE candidates on (e.g. eth0, enp1s0).
HOST_NIC=eth0
# Absolute host path of this repo (must match HOMELAB_REPO_PATH in komodo/compose.env).
# Bind-mount sources MUST be absolute (Komodo periphery's /repo ≠ host path), so any
# stack bind mount should use ${HOMELAB_REPO_PATH}/... — see element-web in compose.yaml.
HOMELAB_REPO_PATH=/home/youruser/homelab
