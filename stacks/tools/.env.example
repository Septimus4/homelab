# tools stack — copy to .env and fill in.
# code-server login password, argon2-hashed.
# Generate: docker run --rm lscr.io/linuxserver/code-server:latest \
#   /lsiopy/bin/python3 -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('YOURPASS'))"
HASHED_PASSWORD=change_me

# Site config (compose interpolation: Traefik Host rules).
DOMAIN=example.com
